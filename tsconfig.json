{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "isomorphic-registry": ["../isomorphic-registry/src/index"],
      "raft-consensus": ["../raft-consensus/src/index"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../isomorphic-registry" },
    { "path": "../raft-consensus" }
  ]
}
